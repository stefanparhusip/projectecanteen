{
    "preset": "laravel",
    "rules": {
        "align_multiline_comment": true,
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    },
    "exclude": [
        "vendor",
        "node_modules",
        "public",
        "storage",
        "bootstrap/cache"
    ]
}
